[
  {
    "corsRuleName": "AllowBrowserUpload",
    "allowedOrigins": ["http://localhost:5173"],
    "allowedHeaders": ["authorization", "content-type", "x-bz-file-name", "x-bz-content-sha1", "range"],
    "allowedOperations": ["b2_upload_file", "b2_upload_part", "b2_download_file_by_name", "b2_download_file_by_id"],
    "exposeHeaders": ["content-range", "content-length", "accept-ranges"],
    "maxAgeSeconds": 3600
  }
]